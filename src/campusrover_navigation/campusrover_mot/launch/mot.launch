<launch>
    <arg name="is_img_label" default="false"/>

    <node pkg="campusrover_mot" type="campusrover_mot_node" name="campusrover_mot_node" output="screen">
        <remap from="points"                to="/velodyne_filter_points"/>
        <remap from="/scan"                 to="/scan"/>
        <remap from="image"                 to="/zed_node/rgb/image_rect_color"/>
        <remap from="camera_info"           to="/zed_node/rgb/camera_info"/>

        <param name="detection_area_min_x"  value="-10.0"/>
        <param name="detection_area_max_x"  value="10.0"/>
        <param name="detection_area_min_y"  value="-10.0"/>
        <param name="detection_area_max_y"  value="10.0"/>
        <param name="detection_area_min_z"  value="-0.05"/>
        <param name="detection_area_max_z " value="0.5"/>
        <param name="track_dead_time "      value="1.0"/>
        <param name="track_older_age "      value="0.5"/>
        <param name="cluster_dist "         value="0.35"/>
        <param name="false_alarm_min "      value="10"/>
        <param name="false_alarm_max "      value="3000"/>

        <param name="weight_min_tolerate"   value="0.01"/>
        <param name="cov_scale"             value="20"/>
        <param name="inherit_ratio"         value="0.6"/>

        <param name="history_length"        value="10"/>
        <param name="anchor_dist_threshold" value="0.1"/>
        <param name="speed_threshold"       value="0.1"/>

        <param name="trackers_update_period"    value="0.05"/>
        <param name="label_update_period"       value="0.1"/>
        <param name="thread_num"                value="4"/>

        <param name="map_frame"             value="map"/>
        <param name="laser_frame"           value="scan"/>
        <param name="camera_frame"          value="camera_link"/>

        <param name="h_scale"               value="2.0"/>
        <param name="v_scale"               value="3.0"/>
        <param name="sync_tolerate"         value="0.08"/>
        <param name="tf_tolerate"           value="1"/>

        <param name="debug_mode"                value="false"/>
        <param name="is_use_laser"              value="false"/>
        <param name="is_map_filter"             value="true"/>
        <param name="is_img_label"              value="$(arg is_img_label)"/>
        <param name="only_dynamic_obstacle"     value="false"/>
    </node>

    <include if="$(arg is_img_label)" file="$(find yolo_ros)/launch/yolo_ros_server.launch">
        <arg name="yolo_v5"                 value="true"/>
        <arg name="yolo_weight_file"        value="$(find yolo_ros)/weights/yolov5.pt"/>
        <arg name="use_cpu"                 value="ture"/>
        <arg name="confident"               value="0.3"/>

    </include>

</launch>
