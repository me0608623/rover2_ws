#!/usr/bin/python3.10

import sys
import os

import yaml
import numpy as np
from PIL import Image
import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, ReliabilityPolicy, HistoryPolicy, DurabilityPolicy
from nav_msgs.msg import OccupancyGrid
from std_msgs.msg import Header


class SimpleMapPublisher(Node):
    def __init__(self):
        super().__init__('map_server')  # Changed from simple_map_publisher to map_server

        # Get map file from parameter
        self.declare_parameter('map_file', '/home/aa/3v3F.yaml')
        map_file = self.get_parameter('map_file').value

        # Create publisher with TRANSIENT_LOCAL QoS
        map_qos = QoSProfile(
            reliability=ReliabilityPolicy.RELIABLE,
            history=HistoryPolicy.KEEP_LAST,
            durability=DurabilityPolicy.TRANSIENT_LOCAL,
            depth=1
        )
        self.map_pub = self.create_publisher(OccupancyGrid, '/map', map_qos)

        # Store reference to prevent garbage collection
        self.occ_grid = None

        # Load and publish map
        self.load_and_publish_map(map_file)

        print(f'Map file: {map_file}')

    def load_and_publish_map(self, yaml_path):
        try:
            with open(yaml_path, 'r') as f:
                map_config = yaml.safe_load(f)

            # Get image path
            image_path = os.path.join(os.path.dirname(yaml_path), map_config['image'])

            # Load image
            img = Image.open(image_path).convert('L')
            img_array = np.asarray(img, dtype=np.uint8)
            img_array = np.flipud(img_array)  # OccupancyGrid data starts from bottom-left

            # Create OccupancyGrid message
            occ_grid = OccupancyGrid()
            occ_grid.header = Header()
            occ_grid.header.frame_id = 'map'
            occ_grid.header.stamp = self.get_clock().now().to_msg()

            # Map metadata
            occ_grid.info.resolution = map_config['resolution']
            occ_grid.info.width = img_array.shape[1]
            occ_grid.info.height = img_array.shape[0]

            # Origin position
            origin = map_config.get('origin', [0.0, 0.0, 0.0])
            occ_grid.info.origin.position.x = float(origin[0])
            occ_grid.info.origin.position.y = float(origin[1])
            occ_grid.info.origin.position.z = float(origin[2])

            # Origin orientation (yaw rotation in radians)
            yaw = map_config.get('yaw', 0.0)
            # Convert yaw (radians) to quaternion
            occ_grid.info.origin.orientation.x = 0.0
            occ_grid.info.origin.orientation.y = 0.0
            occ_grid.info.origin.orientation.z = np.sin(yaw / 2.0)
            occ_grid.info.origin.orientation.w = np.cos(yaw / 2.0)

            # Convert image data
            occupied_thresh = map_config.get('occupied_thresh', 0.65)
            free_thresh = map_config.get('free_thresh', 0.196)
            negate = map_config.get('negate', 0)

            data = []
            for row in img_array:
                for pixel in row:
                    if negate:
                        value = pixel / 255.0
                    else:
                        value = (255 - pixel) / 255.0

                    if value >= occupied_thresh:
                        data.append(100)
                    elif value <= free_thresh:
                        data.append(0)
                    else:
                        data.append(-1)

            occ_grid.data = data

            # Store and publish map
            self.occ_grid = occ_grid
            self.map_pub.publish(occ_grid)

            print(f'Map loaded: {occ_grid.info.width}x{occ_grid.info.height}')

            # Periodic republication
            self.create_timer(1.0, self._republish)

        except Exception as e:
            print(f'Error loading map: {e}')

    def _republish(self):
        if self.occ_grid is not None:
            self.occ_grid.header.stamp = self.get_clock().now().to_msg()
            self.map_pub.publish(self.occ_grid)


def main(args=None):
    rclpy.init(args=args)
    node = SimpleMapPublisher()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
