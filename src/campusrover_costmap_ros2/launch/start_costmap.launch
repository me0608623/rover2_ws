<!-- 
  局部成本地圖啟動文件
  功能：啟動局部成本地圖生成系統
  支援：調試模式、多種感測器輸入、可視化
-->
<launch>
  <!-- 啟動參數 -->
  <arg name="debug"               default="false"/>  <!-- 是否啟用調試模式 -->
  <arg name="bag_filename"        default="$(env HOME)/bags/campusrover_bag/20200409_itc_3f_2s.bag"/>
  
  <!-- ROS 輸入話題配置 -->
  <arg name="only_use_velodyne"        default="false"/>  <!-- 是否只使用 Velodyne 雷達 -->
  <arg if="$(arg only_use_velodyne)"  name="pointcloud" default="/velodyne_points_costmap"/>     <!-- Velodyne 點雲話題 -->
  <arg unless="$(arg only_use_velodyne)"  name="pointcloud" default="laser_cloud"/>              <!-- 2D 雷射轉換的點雲話題 -->

  <!-- 調試模式組：用於離線測試和開發 -->
  <group if="$(arg debug)">
    <!-- 使用模擬時間 -->
    <param name="use_sim_time" value="true" />

    <!-- 播放錄製的數據包 -->
    <node name="playbag" pkg="rosbag" type="play"
          args="--clock $(arg bag_filename)" />

    <!-- 載入機器人描述文件 -->
    <param name="robot_description"
           textfile="$(find campusrover_description)/urdf/campusrover.urdf" />
    <node name="robot_state_publisher" pkg="robot_state_publisher" 
          type="robot_state_publisher" />

    <!-- 靜態 TF 變換：地圖座標系到機器人基礎座標系 -->
    <node pkg="tf2_ros" type="static_transform_publisher"
          name="map_broadcaster" args="0 0 0 0 0 0 1 /map /base_link" />
    
    <!-- 包含雷射感測器啟動文件 -->
    <include file="$(find campusrover_sensors)/launch/ira_laser.launch" />

    <!-- RViz 可視化：顯示成本地圖和機器人狀態 -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find campusrover_costmap)/rviz/campusrover_costmap.rviz" />
  </group>

  <!-- 局部成本地圖節點：從點雲生成局部成本地圖 -->
  <node name="campusrover_costmap" pkg="campusrover_costmap" type="local_costmap_node" output="screen">
    <!-- 話題重映射 -->
    <remap from="points2"             to="$(arg pointcloud)" />
    
    <!-- 可視化參數 -->
    <param name="pcl_viz"             type="bool"   value="false" />  <!-- 是否啟用 PCL 可視化 -->
    
    <!-- 地圖尺寸參數 -->
    <param name="map_size_width"      type="double" value="6" />      <!-- 地圖寬度 (公尺) -->
    <param name="map_size_height"     type="double" value="6" />      <!-- 地圖高度 (公尺) -->
    <param name="map_resolution"      type="double" value="0.02" />   <!-- 地圖解析度 (公尺/像素) -->
    
    <!-- 障礙物檢測參數 -->
    <param name="max_obstacle_height" type="double" value="2.0" />    <!-- 障礙物最大高度 (公尺) -->
    <param name="min_obstacle_height" type="double" value="-1.2" />   <!-- 障礙物最小高度 (公尺) -->

    <!-- 膨脹參數 -->
    <param name="inflation_radius"    type="double" value="0.02" />   <!-- 膨脹半徑 (公尺) -->
    <param name="cost_scaling_factor" type="double" value="10.0" />   <!-- 成本縮放因子 -->
  </node>

  <!-- 雷射轉點雲節點：將 2D 雷射掃描轉換為點雲 (僅在非 Velodyne 模式下啟動) -->
  <node unless="$(arg only_use_velodyne)" name="laser_to_pointcloud2" pkg="campusrover_costmap" type="laser_to_pointcloud2">
    <remap from="laser" to="/scan" />          <!-- 輸入：雷射掃描數據 -->
    <remap from="pointcloud" to="laser_cloud" /> <!-- 輸出：轉換後的點雲 -->
  </node>

  <!-- 電梯成本地圖節點 (已停用) -->
  <!-- <node unless="$(arg only_use_velodyne)" name="elevator_costmap" pkg="campusrover_costmap" type="elevator_costmap">
    <remap from="laser" to="/scan" />
    <remap from="velodyne" to="/velodyne_points" />
    <remap from="pointcloud" to="laser_cloud" />
  </node> -->

</launch>
